alert tcp any any -> $HOME_NET any (msg:"THOR Perl Reverse Shell Pattern"; content:"use Socket"; content:"exec(\"/bin/sh\")"; sid:1000014; rev:2;)
alert tcp any any -> $HOME_NET any (msg:"THOR PHP Reverse Shell Pattern"; content:"<?php"; content:"exec("; content:"shell_exec("; sid:1000015; rev:2;)
alert tcp any any -> $HOME_NET any (msg:"THOR Ruby Reverse Shell Pattern"; content:"require 'socket'"; content:"exec \"/bin/sh\""; sid:1000016; rev:2;)
alert tcp any any -> $HOME_NET any (msg:"THOR Netcat -e Shell"; content:"nc "; content:"-e /bin/"; sid:1000017; rev:2;)
