# =============================================================================
# Thor Firewall Smart — Environment Variables Template
# NEVER commit the actual .env file to version control
# Copy this file to .env and fill all values before first run
# Generate secrets with: openssl rand -hex 64
# =============================================================================

# --- Database (Required) ---
POSTGRES_USER=thor
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
POSTGRES_DB=thor_control
DATABASE_URL=postgres://thor:CHANGE_ME@postgres:5432/thor_control

# --- Redis (Required) ---
REDIS_URL=redis://redis:6379

# --- JWT Authentication (Required) ---
# MUST be generated before first run:  openssl rand -hex 64
THOR_JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_64
THOR_JWT_EXPIRY_HOURS=8

# --- Initial Admin Credentials (Required) ---
THOR_ADMIN_USERNAME=admin
THOR_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_16_CHARS

# --- Agent Network Config ---
THOR_INTERFACE=eth0
THOR_API_ADDR=0.0.0.0:8080
THOR_SIGMA_DIR=rules/sigma
THOR_YARA_DIR=rules/yara
THOR_MODEL=models/thor_ueba_model.onnx

# --- SOAR Integration (Optional) ---
THEHIVE_URL=https://thehive.internal:9000
THEHIVE_API_KEY=CHANGE_ME

# --- Audit Log ---
THOR_AUDIT_DB_PATH=/var/lib/thor/audit.db

# --- Logging ---
RUST_LOG=thor_agent=info,aya=warn

# --- Dashboard ---
REACT_APP_API_URL=http://localhost:8080
