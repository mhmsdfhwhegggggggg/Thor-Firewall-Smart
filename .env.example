# ════════════════════════════════════════════════════════════════════════════════
# Thor Firewall Smart — Production Environment Variables
# Copy to .env and fill in all values before deploying.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ─── Core auth ────────────────────────────────────────────────────────────────
THOR_JWT_SECRET=                        # openssl rand -hex 64
THOR_JWT_EXPIRY_HOURS=8
THOR_ADMIN_USERNAME=thor_admin
THOR_ADMIN_PASSWORD=                    # openssl rand -base64 32 (min 20 chars)

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://thor_user:CHANGE_ME@postgres:5432/thor?sslmode=require
DB_PASSWORD=                            # openssl rand -base64 32

# ─── Redis ────────────────────────────────────────────────────────────────────
THOR_REDIS_URL=redis://:CHANGE_ME@redis-master:6379
REDIS_PASSWORD=                         # openssl rand -base64 32

# ─── Kafka ────────────────────────────────────────────────────────────────────
THOR_KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
THOR_KAFKA_TOPIC_PREFIX=thor
THOR_KAFKA_ACKS=all
THOR_KAFKA_LINGER_MS=5
THOR_KAFKA_COMPRESSION=lz4

# ─── mTLS ─────────────────────────────────────────────────────────────────────
THOR_TLS_CA_CERT=./certs/ca/ca.crt
THOR_TLS_CERT=./certs/thor-agent/agent.crt
THOR_TLS_KEY=./certs/thor-agent/agent.key
THOR_TLS_BIND_ADDR=0.0.0.0:8443
THOR_TLS_MIN_VERSION=1.3

# ─── Network ──────────────────────────────────────────────────────────────────
THOR_INTERFACE=eth0                     # Network interface to monitor
THOR_API_BIND=0.0.0.0:8080
THOR_METRICS_BIND=0.0.0.0:9090
THOR_RATE_LOGIN_RPM=10
THOR_RATE_API_RPM=600

# ─── GeoIP ────────────────────────────────────────────────────────────────────
THOR_GEO_BLOCK_COUNTRIES=KP,IR,SY,CU   # ISO-3166-1 alpha-2 codes
THOR_GEO_ALERT_COUNTRIES=RU,CN
THOR_GEO_ALLOW_COUNTRIES=
THOR_MAXMIND_DB_PATH=                  # /opt/GeoLite2-Country.mmdb

# ─── Threat Intel ─────────────────────────────────────────────────────────────
THOR_INTEL_REFRESH=60
THOR_OTX_API_KEY=
THOR_MISP_URL=
THOR_MISP_KEY=

# ─── Sandbox ──────────────────────────────────────────────────────────────────
THOR_SANDBOX_BACKEND=none              # cape | virustotal | none
THOR_CAPE_URL=
THOR_CAPE_API_KEY=
THOR_VT_API_KEY=
THOR_SANDBOX_TIMEOUT=600

# ─── SIEM ─────────────────────────────────────────────────────────────────────
THOR_SIEM_ENDPOINT=
THOR_SIEM_API_KEY=
THOR_SIEM_FORMAT=cef

# ─── Campaign correlation ──────────────────────────────────────────────────────
THOR_CAMPAIGN_WINDOW_MINS=60

# ─── Kafka mTLS ───────────────────────────────────────────────────────────────
THOR_KAFKA_CLIENT_CERT=./certs/kafka/kafka-client.crt
THOR_KAFKA_CLIENT_KEY=./certs/kafka/kafka-client.key
THOR_KAFKA_CA_CERT=./certs/ca/ca.crt

# ─── Shadow Mode ──────────────────────────────────────────────────────────────
THOR_SHADOW_MODE=false

# ─── Monitoring ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=
DOMAIN=thor.security.internal

# ─── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=thor_agent=info,aya=warn,tower_http=warn
