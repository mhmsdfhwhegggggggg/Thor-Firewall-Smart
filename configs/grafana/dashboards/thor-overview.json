{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    }
  ],
  "id": null,
  "uid": "thor-overview",
  "title": "Thor Firewall \u2014 Security Overview",
  "description": "Real-time security metrics for Thor Firewall Smart",
  "tags": [
    "thor",
    "security",
    "xdp",
    "ebpf"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "title": "XDP Packets/sec",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(thor_xdp_packets_total[1m])",
          "legendFormat": "pps",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000000
              },
              {
                "color": "red",
                "value": 15000000
              }
            ]
          },
          "unit": "pps"
        }
      }
    },
    {
      "type": "stat",
      "id": 2,
      "title": "XDP Drops/sec",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(thor_xdp_drops_total[1m])",
          "legendFormat": "drops/sec",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1000
              },
              {
                "color": "red",
                "value": 10000
              }
            ]
          },
          "unit": "reqps"
        }
      }
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Active Threats",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "thor_active_campaigns",
          "legendFormat": "campaigns",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "id": 4,
      "title": "Blocked IPs (Blocklist)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "expr": "thor_blocklist_size",
          "legendFormat": "IPs",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Alert Rate by Severity",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(thor_alerts_total{level=\"critical\"}[5m])",
          "legendFormat": "Critical",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(thor_alerts_total{level=\"high\"}[5m])",
          "legendFormat": "High",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(thor_alerts_total{level=\"medium\"}[5m])",
          "legendFormat": "Medium",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(thor_alerts_total{level=\"low\"}[5m])",
          "legendFormat": "Low",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Critical"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "High"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "id": 11,
      "title": "WAF Requests vs Blocked",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "expr": "rate(thor_waf_requests_total[1m])",
          "legendFormat": "Total Requests",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(thor_waf_blocked_total[1m])",
          "legendFormat": "Blocked",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(thor_waf_owasp_matches_total[1m])",
          "legendFormat": "OWASP Match",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "gauge",
      "id": 20,
      "title": "ML Inference P99 Latency",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(thor_ml_inference_duration_seconds_bucket[5m]))",
          "legendFormat": "P99",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "max": 2,
          "min": 0
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "type": "gauge",
      "id": 21,
      "title": "ML Anomaly Score (avg)",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 12
      },
      "targets": [
        {
          "expr": "avg(thor_ml_anomaly_score)",
          "legendFormat": "score",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "red",
                "value": 0.85
              }
            ]
          },
          "max": 1,
          "min": 0
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "id": 22,
      "title": "ML Confidence Distribution",
      "gridPos": {
        "h": 5,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(thor_ml_confidence_bucket[5m]))",
          "legendFormat": "P50",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "histogram_quantile(0.95, rate(thor_ml_confidence_bucket[5m]))",
          "legendFormat": "P95",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "histogram_quantile(0.99, rate(thor_ml_confidence_bucket[5m]))",
          "legendFormat": "P99",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "type": "table",
      "id": 30,
      "title": "Agent Fleet Status",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "targets": [
        {
          "expr": "up{job=~\"thor-.*\"}",
          "legendFormat": "{{job}} \u2014 {{instance}}",
          "instant": true,
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {}
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "custom": {
            "displayMode": "color-background"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "id": 31,
      "title": "SOC Event Throughput (events/sec)",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "targets": [
        {
          "expr": "rate(thor_events_processed_total[1m])",
          "legendFormat": "Processed",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "rate(thor_events_dropped_total[1m])",
          "legendFormat": "Dropped",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "type": "timeseries",
      "id": 40,
      "title": "PostgreSQL \u2014 Active Connections",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "Active",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "type": "timeseries",
      "id": 41,
      "title": "Redis \u2014 Operations/sec",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 8,
        "y": 23
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "ops/sec",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },
    {
      "type": "timeseries",
      "id": 42,
      "title": "IOC Cache \u2014 Hit Rate",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 16,
        "y": 23
      },
      "targets": [
        {
          "expr": "rate(thor_ioc_cache_hits_total[5m]) / (rate(thor_ioc_cache_hits_total[5m]) + rate(thor_ioc_cache_misses_total[5m]))",
          "legendFormat": "Hit Rate",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    }
  ]
}